{
  "name": "gbn-3611",
  "private": true,
  "description": "",
  "license": "",
  "sideEffects": false,
  "scripts": {
    "build": "run-s build:*",
    "build:css": "npm run generate:css -- --minify",
    "build:remix": "remix build",
    "dev": "run-p dev:*",
    "dev:css": "npm run generate:css -- --watch",
    "dev:remix": "cross-env NODE_ENV=development binode --require ./mocks -- @remix-run/dev:remix dev",
    "dev:studio": "prisma studio --browser none --port 3001",
    "format": "prettier --write .",
    "generate:css": "tailwindcss -o ./app/styles/tailwind.css",
    "postinstall": "remix setup node",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "setup": "prisma migrate dev && prisma db seed",
    "start": "remix-serve build",
    "start:mocks": "binode --require ./mocks -- @remix-run/serve:remix-serve build",
    "test": "vitest",
    "typecheck": "tsc -b",
    "validate": "run-p \"test -- --run\" lint typecheck"
  },
  "prettier": {
    "printWidth": 120
  },
  "eslintIgnore": [
    "/node_modules",
    "/build",
    "/public/build"
  ],
  "dependencies": {
    "@prisma/client": "3.12.0",
    "@remix-run/react": "1.3.4",
    "@remix-run/serve": "1.3.4",
    "bcryptjs": "2.4.3",
    "isbot": "3.4.5",
    "react": "18.0.0",
    "react-dom": "18.0.0",
    "remix": "1.3.4",
    "tiny-invariant": "1.2.0"
  },
  "devDependencies": {
    "@faker-js/faker": "6.1.2",
    "@remix-run/dev": "1.3.4",
    "@remix-run/eslint-config": "1.3.4",
    "@testing-library/jest-dom": "5.16.4",
    "@testing-library/react": "13.0.0",
    "@testing-library/user-event": "14.0.4",
    "@types/bcryptjs": "2.4.2",
    "@types/eslint": "8.4.1",
    "@types/react": "17.0.43",
    "@types/react-dom": "17.0.14",
    "@vitejs/plugin-react": "1.3.0",
    "binode": "1.0.5",
    "c8": "7.11.0",
    "cross-env": "7.0.3",
    "eslint": "8.12.0",
    "eslint-config-prettier": "8.5.0",
    "happy-dom": "2.55.0",
    "msw": "0.39.2",
    "npm-run-all": "4.1.5",
    "prettier": "2.6.2",
    "prettier-plugin-tailwindcss": "0.1.8",
    "prisma": "3.12.0",
    "tailwindcss": "3.0.23",
    "ts-node": "10.7.0",
    "tsconfig-paths": "3.14.1",
    "typescript": "4.6.3",
    "vite-tsconfig-paths": "3.4.1",
    "vitest": "0.9.0"
  },
  "engines": {
    "node": ">=16"
  },
  "prisma": {
    "seed": "ts-node --require tsconfig-paths/register prisma/seed.ts"
  }
}
